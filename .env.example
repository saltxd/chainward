# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Database + Redis
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://chainward:localdev@localhost:5432/chainward
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-string-minimum

# ─────────────────────────────────────────────────────────────────────────────
# RPC — Base
# Order of fallback: PRIMARY → FALLBACK (secondary) → TERTIARY (final).
# Per BookStack page 182 (2026-04-18 design lock):
#   PRIMARY  = Alchemy (live tip)
#   FALLBACK = cw-sentinel reth (decoder-assist, ~20h behind tip — see page 114)
#   TERTIARY = public Base RPC
# ─────────────────────────────────────────────────────────────────────────────
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_FALLBACK_URL=
BASE_RPC_TERTIARY_URL=https://mainnet.base.org
CHAIN_PROVIDER=alchemy

# ─────────────────────────────────────────────────────────────────────────────
# Alchemy (webhooks stay on Alchemy regardless of CHAIN_PROVIDER)
# ─────────────────────────────────────────────────────────────────────────────
ALCHEMY_API_KEY=YOUR_ALCHEMY_API_KEY
ALCHEMY_WEBHOOK_SIGNING_KEY=
ALCHEMY_AUTH_TOKEN=
ALCHEMY_WEBHOOK_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Delivery channels
# ─────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_TEST_WEBHOOK=
# Weekly digest auto-post target (Discord). Leave blank to disable.
DIGEST_DISCORD_WEBHOOK=

# ─────────────────────────────────────────────────────────────────────────────
# External APIs (optional)
# ─────────────────────────────────────────────────────────────────────────────
# COINGECKO_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Solana (Phase 2 — not active)
# ─────────────────────────────────────────────────────────────────────────────
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# HELIUS_API_KEY=YOUR_HELIUS_API_KEY

# ─────────────────────────────────────────────────────────────────────────────
# Web (Next.js) — public vars exposed in browser bundle
# ─────────────────────────────────────────────────────────────────────────────
# WalletConnect (optional — MetaMask/Coinbase work without it)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Treasury wallet for the in-app pay button
NEXT_PUBLIC_TREASURY_ADDRESS=
TREASURY_WALLET_ADDRESS=

# ─────────────────────────────────────────────────────────────────────────────
# Web (Next.js) — internal cluster URLs (server-side only)
# ─────────────────────────────────────────────────────────────────────────────
# In K3s the web pod proxies to the api Service over cluster DNS
API_INTERNAL_URL=http://api.chainward.svc.cluster.local:8000
# Umami analytics, served at /u/* from the web app
UMAMI_INTERNAL_URL=http://umami.umami.svc.cluster.local:3000
