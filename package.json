{
  "name": "chainward",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @chainward/db generate",
    "db:migrate": "pnpm --filter @chainward/db migrate",
    "db:push": "pnpm --filter @chainward/db push",
    "db:seed": "pnpm --filter @chainward/db seed",
    "db:studio": "pnpm --filter @chainward/db studio",
    "decode:candidates": "tsx scripts/decode-candidates.ts",
    "decode:og-render": "tsx scripts/auto-decode/og-render.ts",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
