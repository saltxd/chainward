{
  "name": "agentguard",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @agentguard/db generate",
    "db:migrate": "pnpm --filter @agentguard/db migrate",
    "db:push": "pnpm --filter @agentguard/db push",
    "db:seed": "pnpm --filter @agentguard/db seed",
    "db:studio": "pnpm --filter @agentguard/db studio",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
