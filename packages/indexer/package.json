{
  "name": "@agentguard/indexer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentguard/db": "workspace:*",
    "@agentguard/common": "workspace:*",
    "bullmq": "^5.25.0",
    "ioredis": "^5.4.0",
    "drizzle-orm": "^0.45.0",
    "viem": "^2.21.0",
    "pino": "^9.6.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "pino-pretty": "^13.0.0",
    "@types/node": "^22.10.0"
  }
}
