{
  "name": "@chainward/virtuals-plugin",
  "version": "0.1.4",
  "description": "ChainWard plugin for Virtuals GAME SDK — real-time monitoring & alerts for AI agent wallets on Base",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@chainward/sdk": "^0.1.0"
  },
  "peerDependencies": {
    "@virtuals-protocol/game": ">=0.1.0"
  },
  "devDependencies": {
    "@virtuals-protocol/game": "^0.1.14",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "virtuals",
    "game",
    "game-sdk",
    "chainward",
    "monitoring",
    "agent",
    "wallet",
    "base",
    "alerts"
  ],
  "license": "MIT",
  "homepage": "https://chainward.ai"
}
