{
  "name": "@chainward/agentkit-plugin",
  "version": "0.1.0",
  "description": "ChainWard action provider for Coinbase AgentKit — real-time monitoring & alerts for AI agent wallets on Base",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@chainward/sdk": "^0.1.0",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@coinbase/agentkit": ">=0.2.0"
  },
  "devDependencies": {
    "@coinbase/agentkit": "^0.2.0",
    "@swc/core": "^1.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "zod": "^3.23.0"
  },
  "keywords": [
    "coinbase",
    "agentkit",
    "chainward",
    "monitoring",
    "agent",
    "wallet",
    "base",
    "alerts",
    "action-provider"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/saltxd/chainward.git",
    "directory": "packages/agentkit-plugin"
  }
}
