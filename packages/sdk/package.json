{
  "name": "@chainward/sdk",
  "version": "0.1.1",
  "description": "ChainWard TypeScript SDK — programmatic access to agent monitoring & alerts on Base",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "chainward",
    "agent",
    "monitoring",
    "wallet",
    "base",
    "alerts",
    "sdk"
  ],
  "license": "MIT",
  "homepage": "https://chainward.ai"
}
